# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Unipile (messaging) — https://developer.unipile.com ─
UNIPILE_API_URL=https://apiXXX.unipile.com:PORT/api/v1
UNIPILE_ACCESS_TOKEN=
UNIPILE_DSN=apiXXX.unipile.com:PORT

# ─── Ollama / Gemma (AI summary + smart reply) ────────────
# Local dev (default if unset): http://127.0.0.1:11434
# Production: MUST be a public URL — Vercel cannot reach your laptop.
# Example: https://ollama.yourdomain.com  (no trailing slash)
OLLAMA_URL=http://127.0.0.1:11434

# Model name as shown by `ollama list` (e.g. gemma2:9b, llama3.2:3b)
AI_MODEL=gemma4:e4b

# Optional — if Ollama is behind nginx/Caddy with Bearer auth
# OLLAMA_API_KEY=
