# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Supabase (ERP data + auth) — Phase 0+ ───────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: Supabase CLI (`npm run db:login` / `db:push`). Create at https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=

# ─── Redis (cache, rate limit, locks) ─────────────────────
# Redis Cloud: subscription/database id is shown in the console (e.g. 14180855) — not the password.
# Endpoint example: redis-15297.c273.us-east-1-2.ec2.cloud.redislabs.com:PORT
# You must copy the "Default user" password from Redis Cloud → your database → Security.
REDIS_URL=redis://default:YOUR_REDIS_CLOUD_PASSWORD@redis-15297.c273.us-east-1-2.ec2.cloud.redislabs.com:15297

# ─── Bonsai / Elasticsearch (global search) ──────────────
# Full URL with embedded basic auth, e.g. https://user:pass@host
BONSAI_URL=

# One-time index creation: GET /api/admin/setup-indexes with header x-hub-admin-secret
HUB_ADMIN_SETUP_SECRET=generate-a-long-random-string

# Hub UI: show legacy persona/role simulator in header (dev only; omit in production)
NEXT_PUBLIC_ENABLE_PERSONA_SIMULATOR=false

# Dev only: skip login for /hub + all hub APIs (never enable in production).
# All three are required together — HUB_BYPASS_AUTH=1 alone will not authorize /api/*.
HUB_BYPASS_AUTH=0
# UUIDs from Supabase: profiles.org_id and auth.users.id (same as profiles.id)
HUB_DEV_ORG_ID=
HUB_DEV_USER_ID=

# ─── Unipile (messaging) — https://developer.unipile.com ─
# Match the host:port from your dashboard; path must end with /api/v1 (same as curl …/api/v1/accounts).
UNIPILE_API_URL=https://api36.unipile.com:16649/api/v1
UNIPILE_ACCESS_TOKEN=
# Optional override if UNIPILE_API_URL has no port or OAuth needs a different host than the API URL.
UNIPILE_DSN=

# ─── OpenAI-compatible AI (summary + smart reply) ─────────
# Supports any OpenAI-compatible endpoint (OpenAI, Azure via LiteLLM, etc.)
# Paste the secret only — do not add "Bearer "; the app sets Authorization: Bearer <key>.
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://ai.atconglobal.com/v1

# Model for summarize / smart reply (OpenAI-compatible)
AI_MODEL=gpt-4.1-mini

# ─── Ollama (optional) ──────────────────────────────────────
# Summarize / auto-reply use OPENAI_* above. Set OLLAMA_URL only if you want /api/ai/health to verify Ollama.
# OLLAMA_URL=https://your-ollama-or-tunnel.example.com
# Model tag on that server for health checks (defaults to llama3.2:3b if unset)
# OLLAMA_MODEL=llama3.2:3b
# OLLAMA_API_KEY=
